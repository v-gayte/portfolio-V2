---
import MainLayout from "../../layouts/MainLayout.astro";
import { useTranslations } from "../../i18n/ui";

const lang = "en";
const t = useTranslations(lang);

const timeline = [
  {
    year: "2024",
    title: "Freelance Fullstack",
    subtitle: "Independent",
    desc: "Development of modern web applications with React, Astro and Node.js. Creating bespoke digital experiences.",
    color: "border-accent-amber"
  },
  {
    year: "2022",
    title: "R&D Engineer",
    subtitle: "Tech Corp",
    desc: "Design of cloud solutions and micro-services. Performance optimization and software architecture.",
    color: "border-indigo-400"
  },
  {
    year: "2020",
    title: "Master in CS",
    subtitle: "Tech University",
    desc: "Specialization in Artificial Intelligence and Software Engineering. Research projects in computer vision.",
    color: "border-emerald-400"
  },
  {
    year: "2018",
    title: "Dev Intern",
    subtitle: "Innovative Startup",
    desc: "First steps in professional web development. Learning agile methodologies.",
    color: "border-rose-400"
  },
  {
    year: "2017",
    title: "Associate Degree",
    subtitle: "IUT",
    desc: "Solid training in algorithms, databases and systems development.",
    color: "border-cyan-400"
  }
];
---

<MainLayout
  title={`${t("journey.title")} | Virgil`}
  description="My Journey"
  lang={lang}
>
  <main class="h-[100dvh] w-full bg-warm-grey pt-20 pb-4 flex flex-col overflow-hidden">
    <!-- Header Fixed -->
    <div class="px-8 md:px-16 pt-8 pb-4 z-10 bg-warm-grey">
      <h1 class="text-4xl md:text-6xl font-slab font-bold text-text-cream mb-2">
        {t("journey.title")}<span class="text-accent-amber">.</span>
      </h1>
      <p class="text-vintage-cream-dark text-lg">
        Scroll right to explore the history.
      </p>
    </div>

    <!-- Horizontal Scroll Container -->
    <div class="flex-1 overflow-x-auto overflow-y-hidden horizontal-scroll flex items-center px-8 md:px-16 gap-4 md:gap-8 pb-6">
      <!-- Spacer start -->
      <div class="w-8 shrink-0"></div>

      {timeline.map((item, index) => (
        <div class="shrink-0 w-[85vw] md:w-[500px] h-[50vh] min-h-[320px] max-h-[450px] relative group transition-transform duration-500 hover:-translate-y-2">
          <!-- Card Content -->
          <div class={`h-full bg-vintage-grey/40 backdrop-blur-md border-l-4 ${item.color} p-5 md:p-8 rounded-r-xl border-y border-r border-white/5 flex flex-col justify-between hover:bg-vintage-grey/60 transition-colors shadow-2xl`}>
             
             <!-- Top: Year & Title -->
             <div>
               <span class="text-6xl md:text-8xl font-slab font-bold text-white/5 absolute -top-10 -right-4 z-0 group-hover:text-white/10 transition-colors select-none">
                 {item.year}
               </span>
               <div class="relative z-10">
                 <div class="text-accent-amber font-mono mb-1 md:mb-2 text-base md:text-lg">{item.year}</div>
                 <h2 class="text-xl md:text-3xl font-bold text-text-cream mb-1 md:mb-2 uppercase tracking-tight">{item.title}</h2>
                 <h3 class="text-base md:text-lg text-white/60 font-light italic">{item.subtitle}</h3>
               </div>
             </div>

             <!-- Bottom: Description -->
             <div class="relative z-10 border-t border-white/10 pt-4 md:pt-6">
               <p class="text-base md:text-lg text-vintage-cream-dark leading-relaxed">
                 {item.desc}
               </p>
             </div>
          </div>
        </div>
      ))}
      
      <!-- Spacer end -->
      <div class="w-8 shrink-0"></div>
    </div>
  </main>
</MainLayout>

<style>
  /* Custom Scrollbar */
  .horizontal-scroll::-webkit-scrollbar {
    height: 8px;
  }
  .horizontal-scroll::-webkit-scrollbar-track {
    background: #1a1a1b;
  }
  .horizontal-scroll::-webkit-scrollbar-thumb {
    background: #2a2a2b;
    border-radius: 4px;
  }
  .horizontal-scroll::-webkit-scrollbar-thumb:hover {
    background: #ffbf00;
  }

  /* Support for mouse wheel horizontal scrolling if needed via JS, strictly CSS here */
  .horizontal-scroll {
    scrollbar-width: thin;
    scrollbar-color: #2a2a2b #1a1a1b;
  }
</style>

<script>
  // Transform vertical scroll to horizontal scroll
  const scrollContainer = document.querySelector('.horizontal-scroll');
  
  if (scrollContainer) {
    window.addEventListener('wheel', (evt) => {
      // @ts-ignore
      if (evt.deltaY !== 0) {
        // @ts-ignore
        scrollContainer.scrollLeft += evt.deltaY;
        evt.preventDefault();
      }
    }, { passive: false });
  }
</script>
