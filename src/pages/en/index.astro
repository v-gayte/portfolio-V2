---
import MainLayout from "../../layouts/MainLayout.astro";
import { useTranslations } from "../../i18n/ui";

const lang = "en";
const t = useTranslations(lang);
---

<MainLayout
  title="Portfolio | Virgil"
  description="Virgil's Portfolio - Creative Engineer & Fullstack Developer"
  lang={lang}
>
  <main
    class="min-h-[calc(100vh-80px)] bg-warm-grey flex flex-col justify-center relative overflow-hidden"
  >
    <!-- Background Elements -->
    <div class="absolute inset-0 pointer-events-none">
      <div
        class="absolute top-[10%] right-[5%] w-[500px] h-[500px] bg-accent-amber/5 rounded-full blur-[100px] animate-pulse-amber"
      >
      </div>
      <div
        class="absolute bottom-[10%] left-[10%] w-[300px] h-[300px] bg-indigo-500/5 rounded-full blur-[80px]"
      >
      </div>
    </div>

    <div
      class="max-w-[1200px] mx-auto px-8 w-full z-10 grid md:grid-cols-2 gap-12 items-center"
    >
      <!-- Hero Text -->
      <div class="animate-fade-in-up">
        <div
          class="inline-block px-3 py-1 mb-6 border border-accent-amber/30 rounded-full text-accent-amber text-sm font-mono bg-accent-amber/5 backdrop-blur-sm"
        >
          {t("home.welcome")}
        </div>

        <h1
          class="text-5xl md:text-7xl lg:text-8xl font-slab font-bold text-text-cream mb-6 leading-[1.1]"
        >
          Creative <br />
          <span
            class="text-transparent bg-clip-text bg-gradient-to-r from-accent-amber to-vintage-amber-light"
            >Engineer</span
          >
        </h1>

        <p
          class="text-xl text-vintage-cream-dark max-w-lg mb-8 font-sans leading-relaxed"
        >
          I design immersive digital experiences and robust technical solutions.
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href={`/${lang}/projets`}
            class="px-8 py-4 bg-text-cream text-warm-grey font-sans font-bold text-lg rounded hover:bg-accent-amber hover:text-warm-grey transition-all transform hover:-translate-y-1 text-center"
            data-hoverable
          >
            View my projects
          </a>
          <a
            href={`/${lang}/contact`}
            class="px-8 py-4 bg-transparent border border-white/20 text-text-cream font-sans font-medium text-lg rounded hover:border-accent-amber hover:text-accent-amber transition-all text-center"
            data-hoverable
          >
            Contact me
          </a>
        </div>
      </div>

      <!-- Hero Visual / Decoration -->
      <div
        class="hidden md:flex justify-center items-center animate-fade-in-up delay-200"
      >
        <div class="relative w-[400px] h-[400px]">
          <!-- Abstract shapes using CSS/SVG -->
          <div
            class="absolute inset-0 border border-white/5 rounded-full animate-rotate-slow"
          >
          </div>
          <div
            class="absolute inset-12 border border-accent-amber/20 rounded-full animate-rotate-slow [animation-direction:reverse]"
          >
          </div>
          <div class="absolute inset-0 flex items-center justify-center">
            <div
              class="w-64 h-64 bg-gradient-to-tr from-accent-amber/10 to-transparent rounded-full backdrop-blur-3xl"
            >
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</MainLayout>

<style>
  .delay-200 {
    animation-delay: 200ms;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in-up {
    animation: fadeInUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
</style>
